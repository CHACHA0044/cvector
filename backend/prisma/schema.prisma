datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  category    String
  price       Float
  image       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  isUserAdded Boolean  @default(false)

  @@index([isUserAdded(sort: Desc), updatedAt(sort: Desc), id(sort: Desc)])
  @@index([category, isUserAdded(sort: Desc), updatedAt(sort: Desc), id(sort: Desc)])
}
